# ── Server ──────────────────────────────────────────────
PORT=5000
# Use 'mongo' (Docker service name) when running inside Docker.
# Use 'localhost' when running locally with npm run dev.
MONGO_URI=mongodb://mongo:27017/civicpulse
MONGO_URI_LOCAL=mongodb://localhost:27017/civicpulse
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# ── Client (prefix VITE_ so Vite exposes them) ──────────
VITE_API_URL=http://localhost:5000/api/v1
VITE_APP_NAME=CivicPulse
